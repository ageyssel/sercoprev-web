# Public Supabase configuration. NEXT_PUBLIC values are embedded in the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Server-only Supabase key. Never prefix this variable with NEXT_PUBLIC.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Canonical application URL used in emails and redirects.
APP_BASE_URL=https://www.sercoprev.cl

# Transactional email configuration.
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=SERCOPREV <portal@sercoprev.cl>
NOTIFICATION_ADMIN_EMAILS=contabilidad@sercoprev.cl

# Optional WhatsApp Cloud API integration.
# The template must be approved in Meta and contain three body variables:
# 1) requested document, 2) due date, 3) reminder to review the email.
WHATSAPP_ACCESS_TOKEN=REPLACE_ME
WHATSAPP_PHONE_NUMBER_ID=REPLACE_ME
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v23.0
WHATSAPP_TEMPLATE_LANGUAGE=es_CL
WHATSAPP_DOCUMENT_REQUEST_TEMPLATE=sercoprev_solicitud_documental
